{
  "manifest_version": 3,
  "name": "Mytone Translate",
  "version": "1.0.0",
  "description": "مترجم النبرة - حافظ على نبرتك الأصلية في أي رسالة",
  "permissions": ["activeTab", "storage", "clipboardRead", "clipboardWrite"],
  "host_permissions": ["https://api.groq.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
